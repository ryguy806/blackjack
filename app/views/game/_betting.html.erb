<%= form_with url: game_bet_path, method: :post, local: true do |f| %>
    <div class="bet-form">
        <div>
        <div class="quick-bets">
            <div>
                <p style="color: #FFF;">Custom Bet:</p>
                <div style="display: flex; flex-direction: row; justify-items: center; align-content: center">
                    <span style="font-size: 1.5rem; padding-top: 7px;">$</span>
                    <%= f.number_field :wager, value: 2, min: 2, max: [500, balance].min,
                            placeholder: 'Bet', oninvalid: "this.setCustomValidity('Bet must be greater than 2 and less than or equal to your balance.')",
                        oninput: "this.setCustomValidity('')" %>
                </div>
            </div>
            <div style="margin-left: 30px;"/>
            <div>
                <p style="color: #FFF;">Quick Bet:</p>
                <% [10, 25, 50, 100].each do |amt| %>
                    <button type="button" class="quick-bet btn" data-value="<%= amt %>">$<%= amt %></button>
                <% end %>
            </div>
        </div>
        <div style="height: 50%; margin: auto; padding-top: 9%; padding-left: 20px">
            <%= f.submit 'Deal', class: 'btn btn-green' %>
        </div>
    </div>
<% end %>
